{
  "name": "@quasar/app-vite",
  "version": "3.0.0-beta.19",
  "description": "Quasar Framework App CLI with Vite",
  "keywords": [
    "cli",
    "cordova",
    "electron",
    "pwa",
    "quasar",
    "spa",
    "vite",
    "vue",
    "vuejs",
    "web"
  ],
  "homepage": "https://quasar.dev",
  "bugs": "https://github.com/quasarframework/quasar/issues",
  "license": "MIT",
  "author": {
    "name": "Razvan Stoenescu",
    "email": "razvan.stoenescu@gmail.com",
    "url": "https://github.com/quasarframework"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/quasarframework/quasar"
  },
  "funding": {
    "type": "github",
    "url": "https://donate.quasar.dev"
  },
  "bin": {
    "quasar": "./bin/quasar.js"
  },
  "files": [
    "exports",
    "assets",
    "bin",
    "lib",
    "templates",
    "types"
  ],
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "node": "./exports/wrappers.js",
      "import": "./exports/wrappers.js"
    },
    "./client": {
      "types": "./types/client/src.d.ts"
    },
    "./client/bex": {
      "types": "./types/client/src-bex.d.ts"
    },
    "./client/electron": {
      "types": "./types/client/src-electron.d.ts"
    },
    "./client/pwa": {
      "types": "./types/client/src-pwa.d.ts"
    },
    "./client/ssr": {
      "types": "./types/client/src-ssr.d.ts"
    },
    "./package.json": "./package.json",
    "./bin/quasar": {
      "node": "./bin/quasar.js"
    },
    "./bex/background": {
      "types": "./types/bex/entrypoints/background.d.ts",
      "import": "./exports/bex/background.js"
    },
    "./bex/content": {
      "types": "./types/bex/entrypoints/content.d.ts",
      "import": "./exports/bex/content.js"
    },
    "./bex/private/bex-bridge": {
      "types": "./types/bex/bex-bridge.d.ts",
      "import": "./exports/bex/private/bex-bridge.js"
    },
    "./electron/main": {
      "types": "./types/electron/main-runtime.d.ts",
      "import": "./exports/electron/main-runtime.js"
    },
    "./electron/preload": {
      "types": "./types/electron/preload-runtime.d.ts",
      "import": "./exports/electron/preload-runtime.js"
    },
    "./eslint": {
      "require": "./exports/eslint/eslint.cjs",
      "node": "./exports/eslint/eslint.js",
      "import": "./exports/eslint/eslint.js"
    },
    "./lib/testing.js": {
      "import": "./exports/testing/testing.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "oxfmt && oxlint --fix",
    "lint:check": "oxfmt --check && oxlint",
    "dev": "pnpm --filter app-vite-playground-js dev",
    "dev:ts": "pnpm --filter app-vite-playground-ts dev",
    "build": "pnpm --filter app-vite-playground-js build",
    "build:ts": "pnpm --filter app-vite-playground-ts build"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@quasar/render-ssr-error": "workspace:^",
    "@quasar/ssl-certificate": "workspace:^",
    "@quasar/vite-plugin": "workspace:^",
    "@types/chrome": "^0.1.42",
    "@types/cordova": "^11.0.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "chokidar": "^5.0.0",
    "ci-info": "^4.4.0",
    "confbox": "^0.2.4",
    "cross-spawn": "^7.0.6",
    "dot-prop": "10.1.0",
    "dotenv-expand": "^13.0.0",
    "elementtree": "0.1.7",
    "fflate": "^0.8.2",
    "fs-extra": "^11.3.5",
    "html-minifier-terser": "^7.2.0",
    "kolorist": "^1.8.0",
    "mlly": "^1.8.2",
    "open": "^11.0.0",
    "rolldown": "^1.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.98.0",
    "semver": "^7.7.4",
    "serialize-javascript": "^7.0.5",
    "serve-static": "^2.2.1",
    "tinyglobby": "^0.2.16",
    "ts-essentials": "^10.2.0",
    "vite": "^8.0.11",
    "webpack-merge": "^6.0.1"
  },
  "devDependencies": {
    "@quasar/extras": "workspace:*",
    "pinia": "^3.0.4",
    "quasar": "workspace:^",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "peerDependencies": {
    "@electron/packager": ">= 19",
    "builder-util": ">= 26",
    "electron-builder": ">= 22",
    "pinia": "^2.0.0 || ^3.0.0",
    "quasar": "^2.16.0",
    "typescript": ">= 5",
    "vue": "^3.2.29",
    "vue-router": ">= 5",
    "workbox-build": ">= 7"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "electron-builder": {
      "optional": true
    },
    "@electron/packager": {
      "optional": true
    },
    "builder-util": {
      "optional": true
    },
    "pinia": {
      "optional": true
    },
    "workbox-build": {
      "optional": true
    }
  },
  "engines": {
    "node": "^30 || ^28 || ^26 || ^24 || ^22.22.0"
  },
  "volta": {
    "node": "lts"
  }
}
