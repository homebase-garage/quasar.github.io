{
  "name": "quasar.dev",
  "version": "2.0.0",
  "private": true,
  "description": "Official Quasar Docs Website",
  "author": "Razvan Stoenescu <razvan.stoenescu@gmail.com>",
  "type": "module",
  "scripts": {
    "prepare:types": "quasar prepare --silent",
    "prepare:docs": "node build/copy-quasar-api.js",
    "dev": "pnpm prepare:docs && quasar dev",
    "dev:ssr": "pnpm prepare:docs && quasar dev -m ssr",
    "build": "quasar clean && pnpm prepare:docs && node build/search.js && quasar build -m ssr --no-summary && node build/fix-ssr-manifest.js && mkdir -p dist/quasar.dev/client/examples/ && cp -R src/examples/* dist/quasar.dev/client/examples/ && cp src-ssr/pnpm-workspace.yaml dist/quasar.dev/ && pnpm i --dir dist/quasar.dev && node build/ssg.js",
    "relnotes": "node build/release-notes/index.js",
    "test": "echo \"No test specified\" && exit 0"
  },
  "dependencies": {
    "@quasar/extras": "^2.0.0",
    "prismjs": "^1.29.0",
    "quasar": "^2.19.3",
    "vue": "^3.5.34",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@quasar/app-vite": "^3.0.0-beta.32",
    "fs-extra": "^11.3.5",
    "gray-matter": "^4.0.3",
    "markdown-ast": "^0.3.0",
    "markdown-it": "^14.2.0",
    "markdown-it-container": "^4.0.0",
    "tinyglobby": "^0.2.10",
    "toml": "^4.1.1",
    "workbox-build": "^7.4.1"
  },
  "productName": "quasar-docs"
}
