{
  "name": "playground",
  "version": "0.0.1",
  "private": true,
  "description": "A Quasar App Extension Playground",
  "author": "<%= scope.author %>",
  "type": "module",
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "prepare": "quasar prepare",
    "invoke": "quasar ext invoke <%= scope.aeShortName %>",
    "cycle": "quasar ext uninvoke <%= scope.aeShortName %> && quasar ext invoke <%= scope.aeShortName %>"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "quasar": "catalog:",
    "vue": "catalog:",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@quasar/app-vite": "catalog:",
    "@types/node": "^22.19.11",
    "<%= scope.aeFullName %>": "workspace:*"
  },
  "productName": "Quasar App Extension Playground"
}
