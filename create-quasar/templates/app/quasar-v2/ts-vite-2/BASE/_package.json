{
  "name": "<%= name %>",
  "version": "0.0.1",
  "description": "<%= description %>",
  "productName": "<%= productName %>",
  "author": "<%= author %>",
  "type": "module",
  "private": true,
  "scripts": {
    <% if (preset.eslint) { %>"lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",<% } %>
    <% if (prettier) { %>"format": "prettier --write \"**/*.{js,ts,vue,<% if (css !== 'sass') { %><%= css %><% } %>,html,md,json}\" --ignore-path .gitignore",<% } %>
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    <% if (preset.axios) { %>"axios": "^1.13.6",<% } %>
    <% if (preset.i18n) { %>"vue-i18n": "^11.3.0",<% } %>
    <% if (preset.pinia) { %>"pinia": "^3.0.1",<% } %>
    "@quasar/extras": "^1.16.4",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    <% if (preset.eslint) { %>
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "vue-tsc": "^3.2.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "vite-plugin-checker": "^0.12.0",
    "vue-eslint-parser": "^10.4.0",
    <% } %>
    <% if (prettier) { %>
    "@vue/eslint-config-prettier": "^10.2.0",
    "prettier": "^3.8.1",
    <% } %>
    "@types/node": "^22.19.11",
    <% if (preset.i18n) { %>"@intlify/unplugin-vue-i18n": "^11.0.0",<% } %>
    "@quasar/app-vite": "^2.5.1",
    "autoprefixer": "^10.4.27",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22.12",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}
