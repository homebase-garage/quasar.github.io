{
  "name": "<%= scope.name %>",
  "version": "0.0.1",
  "description": "<%= scope.description %>",
  "productName": "<%= scope.productName %>",
  "author": "<%= scope.author %>",
  "type": "module",
  "private": true,
  "scripts": {
    <% if (scope.linter === 'oxlint') { %>
    "lint": "oxfmt && oxlint --fix",
    "lint:check": "oxfmt --check && oxlint",
    <% } else if (scope.linter === 'eslint') { %>"lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,css<% if (scope.preset.sass) { %>,scss<% } %>,html,md,json}\" --ignore-path .gitignore",<% } %>
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    <% if (scope.preset.i18n) { %>"vue-i18n": "^11.3.0",<% } %>
    <% if (scope.preset.pinia) { %>"pinia": "^3.0.1",<% } %>
    "@quasar/extras": "^1.16.4",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    <% if (scope.preset.i18n) { %>"@intlify/unplugin-vue-i18n": "^11.0.0",<% } %>
    <% if (scope.linter === 'oxlint') { %>
    "oxfmt": "^0.x",
    "oxlint": "^1.63.0",
    <% } else if (scope.linter === 'eslint') { %>
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "vite-plugin-checker": "^0.12.0",
    "vue-eslint-parser": "^10.4.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "prettier": "^3.8.1",
    <% } %>
    "@quasar/app-vite": "^3.0.0-beta.14",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22.12",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10"
  }
}
